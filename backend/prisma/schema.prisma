generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  FLEET_MANAGER
  MAINTENANCE_TECH
}

enum AircraftStatus {
  OPERATIONAL
  MAINTENANCE_REQUIRED
  GROUNDED
}

enum AlertSeverity {
  LOW
  MEDIUM
  CRITICAL
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  role         UserRole  @default(FLEET_MANAGER)
  createdAt    DateTime  @default(now())
}

model Aircraft {
  id                String            @id @default(cuid())
  tailNumber        String            @unique
  model             String
  totalFlightHours  Float             @default(0)
  status            AircraftStatus    @default(OPERATIONAL)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  telemetryLogs     TelemetryLog[]
  maintenanceAlerts MaintenanceAlert[]
}

model TelemetryLog {
  id                String   @id @default(cuid())
  aircraftId        String
  flightNumber      String
  engineTemperature Float
  oilPressure       Float
  vibrationLevel    Float
  altitude          Float
  timestamp         DateTime @default(now())

  aircraft Aircraft @relation(fields: [aircraftId], references: [id], onDelete: Cascade)

  @@index([aircraftId, timestamp])
}

model MaintenanceAlert {
  id          String        @id @default(cuid())
  aircraftId  String
  component   String
  severity    AlertSeverity @default(MEDIUM)
  description String
  isResolved  Boolean       @default(false)
  createdAt   DateTime      @default(now())

  aircraft Aircraft @relation(fields: [aircraftId], references: [id], onDelete: Cascade)

  @@index([aircraftId, isResolved, severity])
}